# Copy this file to .env.local and fill in your values

# ===================
# SUPABASE (Required)
# ===================

# Your Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Supabase Service Role Key (NEVER expose to browser - server-side only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ===================
# SITE CONFIGURATION
# ===================

# Your production URL (without trailing slash)
NEXT_PUBLIC_SITE_URL=https://botsmartafrica.com

# ===================
# ADMIN SECURITY (Optional)
# ===================

# Secret key for admin creation API
ADMIN_CREATION_KEY=your-secret-admin-key

# Comma-separated IP addresses allowed for admin access
# ADMIN_ALLOWED_IPS=192.168.1.1,10.0.0.0/8

# ===================
# STRIPE (Future - Optional)
# ===================

# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
